{
  "name": "a2a-workbench",
  "description": "Local A2A and A2UI protocol workbench for debugging agent endpoints.",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "a2a",
    "a2ui",
    "agents",
    "protocol",
    "workbench"
  ],
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:client && next build",
    "build:client": "npm run build --workspace @a2a-workbench/client",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run && npm run test --workspace @a2a-workbench/client",
    "typecheck": "npm run build:client && tsc --noEmit && npm run typecheck --workspace @a2a-workbench/client",
    "docs:check": "node scripts/check-docs.mjs",
    "conformance:check": "node scripts/check-conformance.mjs",
    "package:smoke": "npm run build:client && node scripts/check-package-exports.mjs",
    "interop:python": "node scripts/run-python-interop.mjs",
    "check": "npm run lint && npm run test && npm run typecheck && npm run docs:check && npm run conformance:check && npm run package:smoke"
  },
  "dependencies": {
    "@a2ui/react": "^0.9.1",
    "@a2ui/web_core": "^0.9.2",
    "lucide-react": "^1.22.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "11.12.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
