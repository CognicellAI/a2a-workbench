# Strict mode: agent origin or full Agent Card URL. Compatibility mode may use
# a direct operation endpoint.
A2A_UPSTREAM=https://agent.example.com
# Compatibility-only text trigger. Strict A2UI uses extension negotiation.
A2A_A2UI_TRIGGER=[a2ui]

# Optional default API-key style header. Secret values are forwarded by the
# server route and redacted from inspector output.
A2A_API_KEY=
A2A_SCOPE_HEADER=X-A2A-Scope-User
A2A_SCOPE_USER=

# Optional OAuth 2.0 client credentials flow.
A2A_OAUTH_ENABLED=false
A2A_OAUTH_TOKEN_URL=
A2A_OAUTH_CLIENT_ID=
A2A_OAUTH_CLIENT_SECRET=
A2A_OAUTH_SCOPE=
A2A_OAUTH_AUDIENCE=
A2A_OAUTH_AUTH_METHOD=client_secret_basic

# Optional hardening for hosted/shared deployments.
# Comma-separated hostnames. Supports exact names, .example.com suffixes, and *.example.com wildcards.
A2A_UPSTREAM_ALLOWLIST=
A2A_ALLOW_PRIVATE_NETWORKS=false
A2A_UPSTREAM_TIMEOUT_MS=120000
A2A_UPSTREAM_MAX_BYTES=10485760
